{
	"name": "fass",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"start": "npx nearleyc ./src/fass.ne --out ./src/fass.cjs && bun src/parse test/test.example",
		"build": "nearleyc ./src/fass.ne --out ./src/fass.cjs",
		"test": "cat src/program.fass | nearley-test src/fass.cjs",
		"build-test": "nearleyc ./src/fass.ne --out ./src/fass.cjs && cat src/program.fass | nearley-test src/fass.cjs",
		"try": "nearleyc ./src/fass.ne --out ./src/fass.cjs && nearley-test src/fass.cjs --input",
		"keygen": "bun ./src/keygen.ts"
	},
	"devDependencies": {
		"@types/antlr4": "^4.11.6",
		"@types/node": "^20.16.11",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"prettier": "^3.3.3"
	},
	"dependencies": {
		"antlr4": "^4.13.2",
		"minimist": "^1.2.8",
		"nearley": "^2.20.1"
	}
}
